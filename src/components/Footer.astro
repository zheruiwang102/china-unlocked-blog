---
const today = new Date();
---

<footer>
	<div>
		<strong>China Unlocked</strong>
		<span>Daily China Signals for readers outside the Chinese internet.</span>
	</div>
	<p>&copy; {today.getFullYear()} China Unlocked. Built from open-source signals and human review.</p>
</footer>
<style>
	footer {
		margin-top: 4rem;
		padding: 2rem 1.5rem;
		background: rgb(var(--ink));
		color: rgb(var(--paper));
	}
	footer div {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1120px;
		margin: 0 auto;
	}
	footer p {
		max-width: 1120px;
		margin: 1rem auto 0;
		color: rgba(var(--paper), 70%);
		font-size: 0.9rem;
	}
	@media (max-width: 720px) {
		footer div {
			flex-direction: column;
		}
	}
</style>
